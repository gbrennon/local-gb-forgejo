# Copy to .env — never commit .env to version control
POSTGRES_DB=db_name
POSTGRES_USER=db_name
POSTGRES_PASSWORD=change_me_strong_password
FORGEJO_ADMIN_USER=change_me_admin_username
FORGEJO_ADMIN_PASSWORD=change_me_strong_password
GITHUB_PAT=change_me_github_pat

# ---------------------------------------------------------------------------
# AI PR Reviewer (optional)
# ---------------------------------------------------------------------------
# Repos to watch for PRs (comma-separated, format: owner/repo)
WATCH_PR_REPOS=

# Codeberg/GitHub API token (required for WATCH_PR_REPOS)
CODEBERG_TOKEN=

# Ollama settings
OLLAMA_HOST=http://host.containers.internal:11434
OLLAMA_MODEL=deepseek-coder:6.7b
